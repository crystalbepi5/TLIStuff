{
  "name": "@torchlight-companion/local-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput & node --watch dist/index.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.mjs",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@torchlight-companion/build-data": "workspace:*",
    "@torchlight-companion/db": "workspace:*",
    "@torchlight-companion/domain": "workspace:*",
    "@torchlight-companion/log-parser": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.13.2"
  }
}
